# Database (Supabase)
DB_HOST=your-project.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USERNAME=postgres
DB_PASSWORD=your-db-password

# JWT
JWT_SECRET=your-very-long-random-secret-key-at-least-32-chars

# AlphaVantage (optional - used as price fallback)
ALPHAVANTAGE_API_KEY=your-key-or-leave-empty

# CORS - add your Railway frontend URL here (comma-separated, no spaces)
# Example: CORS_ALLOWED_ORIGINS=https://finora-ui.up.railway.app,http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:5173
