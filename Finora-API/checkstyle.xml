<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
    Finora – Checkstyle rules
    Severity=error  → fails the build (naming correctness, string equality, duplicate imports)
    Severity=warning → reported only (style preferences)
-->
<module name="Checker">
    <property name="severity" value="error"/>
    <property name="fileExtensions" value="java"/>

    <!-- Tab characters are banned; 4-space indentation is the project standard -->
    <module name="FileTabCharacter">
        <property name="eachLine" value="true"/>
        <property name="severity" value="warning"/>
    </module>

    <!-- Lines beyond 160 chars are a style warning, not a hard error -->
    <module name="LineLength">
        <property name="max" value="160"/>
        <property name="severity" value="warning"/>
    </module>

    <module name="TreeWalker">

        <!-- ── Naming conventions (errors – these are non-negotiable) ─────── -->
        <module name="TypeName"/>
        <module name="PackageName">
            <property name="format" value="^[a-z]+(\.[a-z][a-z0-9_]*)*$"/>
        </module>
        <module name="MethodName"/>
        <module name="ParameterName"/>
        <module name="MemberName"/>
        <module name="StaticVariableName"/>
        <module name="LocalVariableName"/>
        <!-- Allow 'logger' and 'log' — widely accepted SLF4J convention for static final Logger fields -->
        <module name="ConstantName">
            <property name="format" value="^log(ger)?$|^[A-Z][A-Z0-9]*(_[A-Z0-9]+)*$"/>
        </module>

        <!-- ── Import hygiene ────────────────────────────────────────────── -->
        <!-- Redundant import (same package or java.lang) is always an error -->
        <module name="RedundantImport"/>
        <!-- Wildcard imports are a warning; static wildcards allowed in tests -->
        <module name="AvoidStarImport">
            <property name="allowStaticMemberImports" value="true"/>
            <property name="severity" value="warning"/>
        </module>
        <module name="UnusedImports">
            <property name="severity" value="warning"/>
        </module>

        <!-- ── Correctness (errors – potential runtime bugs) ─────────────── -->
        <!-- Using == to compare string literals is always a bug -->
        <module name="StringLiteralEquality"/>

        <!-- ── Code clarity (warnings – good to fix, not release blockers) ── -->
        <module name="SimplifyBooleanExpression">
            <property name="severity" value="warning"/>
        </module>
        <module name="SimplifyBooleanReturn">
            <property name="severity" value="warning"/>
        </module>
        <module name="NeedBraces">
            <property name="severity" value="warning"/>
        </module>
        <module name="ModifierOrder">
            <property name="severity" value="warning"/>
        </module>
        <module name="EmptyBlock">
            <property name="severity" value="warning"/>
        </module>

    </module>
</module>
